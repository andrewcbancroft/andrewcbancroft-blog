# Binaries for programs and plugins
*.exe
*.dll
*.so
*.dylib

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Project-local glide cache, RE: https://github.com/Masterminds/glide/issues/736
.glide/

# Ignore notebooks
.ipynb_checkpoints
*/.ipynb_checkpoints/*


.DS_Store
# Node tooling (OG image generation)
node_modules/

# Unfinished drafts (kept local, not for the public repo)
content/blog/drafts/

# OG design handoff / reference material (not needed to build the site)
design_handoff_og_images/

# BITS slide-deck brand fonts (Instrument Sans / IBM Plex Mono). Reference
# material for Keynote, not a site asset: the site loads its faces from Google
# Fonts. Kept local so it doesn't bloat the published blog repo.
fonts/

# Local-only agent instructions and writing voiceprint. This is a public repo;
# these hold personal strategy and voice notes and must stay off it. Claude Code
# reads them from disk regardless of git tracking. (Purged from history 2026-07-20.)
/CLAUDE.md
/.claude/voiceprint.md

# Internal project working docs (strategy, traffic/revenue analysis, experiment
# thresholds, ESP/brand decisions, redirect runbook, lead-magnet brief). Kept
# local, never published to this public repo. (Purged from history 2026-07-20.)
/project-docs/
